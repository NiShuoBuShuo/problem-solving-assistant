# ── API 类型 ──────────────────────────────────────────────
# anthropic  →  使用 Anthropic 官方 SDK（默认）
# openai     →  使用 OpenAI 兼容接口（适合自定义端点/代理）
# API_TYPE=anthropic
API_TYPE=openai

# ── 模型名称 ──────────────────────────────────────────────
# anthropic 模式默认值：claude-sonnet-4-6
# openai 模式示例：gpt-4o / qwen-vl-max / glm-4v / 自定义模型名
# MODEL=claude-sonnet-4-6
MODEL=qwen3.6-plus

# ── API Key ───────────────────────────────────────────────
# ANTHROPIC_API_KEY=your_anthropic_key_here

# openai 模式时使用（若与 ANTHROPIC_API_KEY 相同可不填）
# OPENAI_API_KEY=your_openai_compatible_key_here

# ── 自定义 Base URL（openai 模式必填，anthropic 模式可选）──
# 示例：
#   阿里云 DashScope:  https://dashscope.aliyuncs.com/compatible-mode/v1
#   智谱 GLM:          https://open.bigmodel.cn/api/paas/v4
#   本地 Ollama:       http://localhost:11434/v1
#   Anthropic 代理:    https://your-proxy.com
# API_BASE_URL=https://your-endpoint.com/v1
OPENAI_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DashScope 等支持深度思考的兼容端点可显式关闭，减少首包延迟
OPENAI_ENABLE_THINKING=false

# 预取后续步骤数，0 表示关闭。建议先从 1 开始。
PREFETCH_STEPS=1

# 会话持久化（服务重启后可恢复）
PERSIST_SESSIONS=true
SESSION_STORE_PATH=data/sessions.json
